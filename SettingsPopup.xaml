<Window
    x:Class="LegendBar.SettingsPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Border CornerRadius="12"
                BorderThickness="0"
                Padding="0"
                Background="Transparent">
            <StackPanel>

                <!-- Header -->
                <StackPanel Padding="20,16,20,0">
                <TextBlock Text="LegendBar Settings"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Tabs -->
                <TabView x:Name="SettingsTabs"
                         Margin="12,8,12,0"
                         IsAddTabButtonVisible="False"
                         VerticalAlignment="Top"
                         BorderThickness="0"
                         BorderBrush="Transparent">

                    <!-- Appearance Tab -->
                    <TabViewItem Header="Appearance"
                                 IsClosable="False">
                        <ScrollViewer Padding="4,12,4,12"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16">

                                <!-- Bar Height -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="BAR HEIGHT"
                                               Foreground="White"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="HeightSlider"
                                                Grid.Column="0"
                                                Minimum="30"
                                                Maximum="80"
                                                ValueChanged="HeightSlider_Changed"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="HeightLabel"
                                                   Grid.Column="1"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Divider -->
                                <Rectangle Height="1" Fill="#22FFFFFF"/>

                                <!-- Acrylic Tint -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="ACRYLIC TINT"
                                               Foreground="White"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="TintSlider"
                                                Grid.Column="0"
                                                Minimum="0"
                                                Maximum="100"
                                                ValueChanged="TintSlider_Changed"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TintLabel"
                                                   Grid.Column="1"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Acrylic Blur -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="ACRYLIC BLUR"
                                               Foreground="White"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="LuminositySlider"
                                                Grid.Column="0"
                                                Minimum="0"
                                                Maximum="100"
                                                ValueChanged="LuminositySlider_Changed"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LuminosityLabel"
                                                   Grid.Column="1"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>

                    <!-- Behavior Tab -->
                    <TabViewItem Header="Behavior"
                                 IsClosable="False">
                        <ScrollViewer Padding="4,12,4,12"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16">

                                <!-- Show Speed -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="SHOW SPEED (MS)"
                                               Foreground="White"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="ShowSpeedSlider"
                                                Grid.Column="0"
                                                Minimum="50"
                                                Maximum="500"
                                                ValueChanged="ShowSpeedSlider_Changed"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ShowSpeedLabel"
                                                   Grid.Column="1"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Hide Speed -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="HIDE SPEED (MS)"
                                               Foreground="White"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="HideSpeedSlider"
                                                Grid.Column="0"
                                                Minimum="50"
                                                Maximum="500"
                                                ValueChanged="HideSpeedSlider_Changed"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="HideSpeedLabel"
                                                   Grid.Column="1"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Hide Delay -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="HIDE DELAY (MS)"
                                               Foreground="White"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="HideDelaySlider"
                                                Grid.Column="0"
                                                Minimum="0"
                                                Maximum="1000"
                                                ValueChanged="HideDelaySlider_Changed"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="HideDelayLabel"
                                                   Grid.Column="1"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Divider -->
                                <Rectangle Height="1" Fill="#22FFFFFF"/>

                                <!-- Temperature Unit -->
                                <StackPanel Spacing="8">
                                    <TextBlock Text="TEMPERATURE UNIT"
                                               Foreground="White"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5"/>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="16">
                                        <RadioButton x:Name="CelsiusRadio"
                                                     Content="°C Celsius"
                                                     Foreground="White"
                                                     FontFamily="Segoe UI"
                                                     FontSize="13"
                                                     Checked="TempUnit_Changed"/>
                                        <RadioButton x:Name="FahrenheitRadio"
                                                     Content="°F Fahrenheit"
                                                     Foreground="White"
                                                     FontFamily="Segoe UI"
                                                     FontSize="13"
                                                     Checked="TempUnit_Changed"/>
                                    </StackPanel>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>

                    <!-- System Tab -->
                    <TabViewItem Header="System"
                                 IsClosable="False">
                        <ScrollViewer Padding="4,12,4,12"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16">

                                <!-- Launch on Startup -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Launch on Startup"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Start LegendBar with Windows"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI"
                                                   FontSize="11"
                                                   Opacity="0.5"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="StartupToggle"
                                                  Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  Toggled="Startup_Toggled"/>
                                </Grid>

                                <!-- Divider -->
                                <Rectangle Height="1" Fill="#22FFFFFF"/>

                                <!-- Reset to Defaults -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="RESET"
                                               Foreground="White"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5"/>
                                    <Button x:Name="ResetButton"
                                            Content="Reset to Defaults"
                                            HorizontalAlignment="Stretch"
                                            Click="Reset_Click"
                                            Foreground="White"
                                            FontFamily="Segoe UI"
                                            FontSize="13"/>
                                </StackPanel>

                                <!-- Divider -->
                                <Rectangle Height="1" Fill="#22FFFFFF"/>

                                <!-- Version -->
                                <TextBlock Text="LegendBar v1.0  —  WinUI 3"
                                           Foreground="White"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           Opacity="0.3"
                                           HorizontalAlignment="Center"/>

                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>

                </TabView>

            </StackPanel>
        </Border>
    </Grid>
</Window>