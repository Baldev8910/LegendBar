<UserControl
    x:Class="LegendBar.Widgets.MediaWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid VerticalAlignment="Center" MaxWidth="5000">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Volume indicator -->
        <Border x:Name="VolumeIndicator"
                Grid.Column="2"
                Background="#33FFFFFF"
                CornerRadius="4"
                Padding="6,2"
                VerticalAlignment="Center"
                Visibility="Collapsed"
                Opacity="0">
            <TextBlock x:Name="VolumeText"
                       Foreground="White"
                       FontSize="11"
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>
        </Border>
        
        <!-- Controls -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="8">

            <Button Click="Previous_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Width="18"
                    Height="18"
                    Opacity="0.7">
                <Image Source="ms-appx:///Assets/Media/skip-back.svg"
                       Width="16"
                       Height="16"/>
            </Button>

            <Button Click="PlayPause_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Width="20"
                    Height="20"
                    Opacity="1.0">
                <Grid>
                    <Image x:Name="PlayIcon"
                           Source="ms-appx:///Assets/Media/play.svg"
                           Width="18"
                           Height="18"/>
                    <Image x:Name="PauseIcon"
                           Source="ms-appx:///Assets/Media/pause.svg"
                           Width="18"
                           Height="18"
                           Visibility="Collapsed"/>
                </Grid>
            </Button>

            <Button Click="Next_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Width="18"
                    Height="18"
                    Opacity="0.7">
                <Image Source="ms-appx:///Assets/Media/skip-forward.svg"
                       Width="16"
                       Height="16"/>
            </Button>

        </StackPanel>

        <!-- Text -->
        <StackPanel Grid.Column="4"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="5">

            <Button x:Name="TitleButton"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    VerticalAlignment="Center"
                    Click="TitleButton_Click">
                            <TextBlock x:Name="TitleText"
                           Text="No media"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="Medium"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="500"
                           VerticalAlignment="Center"/>
            </Button>

            <TextBlock x:Name="DotSeparator"
                       Text="·"
                       Foreground="#66FFFFFF"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <TextBlock x:Name="ArtistText"
                       Foreground="#AAAAAA"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="500"
                       VerticalAlignment="Center"/>

        </StackPanel>

    </Grid>

</UserControl>